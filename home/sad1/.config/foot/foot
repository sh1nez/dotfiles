workers=8

[main]
include=/usr/share/foot/themes/gruvbox-dark
font=monospace:size=13
#font-bold=<bold variant of regular font>
# font-italic=URW Bookman: size=11
# italic:size=11
#<italic variant of regular font>
# font-bold-italic=
# font-size-adjustment=1
# font-monospace-warn=no
# pad=8x8

[bell]
urgent=true

[scrollback]
lines=16384

[url]
launch=xdg-open ${url}
label-letters=sadfjklewcmpgh
osc8-underline=url-mode
protocols=https, http
uri-characters=abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_.,~:;/?#@!$&%*+="'()[]

[key-bindings]
show-urls-launch=Shift+Tab
scrollback-down-line=Control+Shift+j
scrollback-up-line=Control+Shift+k
scrollback-down-half-page=Control+Shift+l
scrollback-up-half-page=Control+Shift+h
scrollback-end=Control+Shift+comma
scrollback-home=Control+Shift+i

[colors]
alpha=0.9
background=181818
